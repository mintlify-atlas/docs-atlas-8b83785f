  "keyFeatures": [
    "Secure user authentication with role-based access control (Admin, User, Guest)",
    "Campaign creation and management with progress tracking",
    "Automated message scheduling with timezone support and recurrence options",
    "Admin dashboard for user approval and session management",
    "Multi-channel notifications via WhatsApp and email",
    "Background scheduler service for automated message delivery",
    "WhatsApp group management with search and pagination",
    "Dynamic message templates with placeholder support"
